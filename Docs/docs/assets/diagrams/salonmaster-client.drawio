          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- PWA / Service Worker -->
        <mxCell id="pwa" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="PWA Service Worker&lt;br&gt;(Offline Shell + Sync)" vertex="1">
          <mxGeometry height="50" width="140" x="40" y="220" as="geometry" />
        </mxCell>
        <mxCell id="edge-pwa-apiclient" edge="1" parent="1" source="pwa" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" target="api-client">
