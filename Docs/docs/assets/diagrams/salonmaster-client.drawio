        <!-- Router -->
        <mxCell id="router" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Router&lt;br&gt;(React Router)" vertex="1">
          <mxGeometry height="60" width="100" x="300" y="220" as="geometry" />
        </mxCell>
        <mxCell id="edge-store-router" edge="1" parent="1" source="store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="router">
          <mxGeometry relative="1" as="geometry" />
