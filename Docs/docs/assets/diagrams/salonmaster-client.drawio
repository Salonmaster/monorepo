<mxfile host="app.diagrams.net">
  <diagram name="SalonMaster Client Architecture" id="sm-client">
    <mxGraphModel dx="1528" dy="893" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Left edge: WebSocket -->
        <mxCell id="ws" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="WebSocket&lt;br&gt;Connection" vertex="1">
          <mxGeometry height="60" width="80" x="40" y="40" as="geometry" />
        </mxCell>
        <!-- Auth Middleware -->
        <mxCell id="auth" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Auth Middleware&lt;br&gt;(JWT + Refresh)" vertex="1">
          <mxGeometry height="60" width="80" x="160" y="40" as="geometry" />
        </mxCell>
        <!-- WS to Auth -->
        <mxCell id="edge-ws-auth" edge="1" parent="1" source="ws" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- API Client -->
        <mxCell id="api-client" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="API Client&lt;br&gt;(REST/WS)" vertex="1">
          <mxGeometry height="60" width="80" x="40" y="130" as="geometry" />
        </mxCell>
        <mxCell id="edge-apiclient-auth" edge="1" parent="1" source="api-client" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Store (state management) -->
        <mxCell id="store" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="App State&lt;br&gt;(Zustand/Redux)" vertex="1">
          <mxGeometry height="60" width="100" x="300" y="40" as="geometry" />
        </mxCell>
        <mxCell id="edge-auth-store" edge="1" parent="1" source="auth" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="store">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Offline Queue -->
        <mxCell id="offline" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;" value="Offline Queue&lt;br&gt;(IndexedDB)" vertex="1">
          <mxGeometry height="60" width="100" x="300" y="130" as="geometry" />
        </mxCell>
        <mxCell id="edge-apiclient-offline" edge="1" parent="1" source="api-client" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="offline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Local DB -->
        <mxCell id="localdb" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;" value="SQLite&lt;br&gt;(Local)" vertex="1">
          <mxGeometry height="60" width="60" x="470" y="40" as="geometry" />
        </mxCell>
        <mxCell id="edge-store-localdb" edge="1" parent="1" source="store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" target="localdb">
          <mxGeometry relative="1" as="geometry" />
