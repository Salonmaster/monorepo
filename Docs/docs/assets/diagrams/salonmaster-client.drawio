        <mxCell id="settings-v" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Settings" vertex="1">
          <mxGeometry height="50" width="120" x="620" y="520" as="geometry" />
        </mxCell>
        <!-- Store to views edges -->
