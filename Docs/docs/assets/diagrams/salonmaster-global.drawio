        <mxCell id="srv-api" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="SalonMaster&lt;br&gt;API Server" vertex="1">
          <mxGeometry height="120" width="120" x="380" y="354" as="geometry" />
        </mxCell>
