# Sample environment configuration for Stylist CLI
ENV=tst
KUBECONFIG=~/.kube/config
SECRETS_DB=/path/to/secrets.db
SECRETS_DB_PASSWORD=changeme
# Optional helper for password rotation
# SECRETS_DB_NEW_PASSWORD=newpassword
# Optional: use S3-compatible storage for the secrets DB
# SECRETS_DB=s3://bucket/path/to/secrets.db
# AWS_S3_ENDPOINT=https://salonmaster-ci.nbg1.your-objectstorage.com
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=access
# AWS_SECRET_ACCESS_KEY=secret
# AWS_SESSION_TOKEN=
