{
  "app": {
    "number_of_threads": 4,
    "enable_session": false,
    "document_root": "./",
    "upload_path": "uploads",
    "max_connections": 10000,
    "max_connections_per_ip": 0,
    "log": {
      "use_spdlog": true,
      "logfile_base_name": "",
      "log_size_limit": 100000000,
      "log_level": "DEBUG",
      "display_local_time": true
    },
    "run_as_daemon": false,
    "handle_sig_term": true,
    "relaunch_on_error": false,
    "use_sendfile": true,
    "use_gzip": true,
    "static_files_cache_time": 5,
    "idle_connection_timeout": 60,
    "server_header_field": "SalonMaster",
    "enable_server_header": true,
    "enable_date_header": true,
    "keepalive_requests": 100,
    "pipelining_requests": 0,
    "gzip_static": true,
    "br_static": false,
    "client_max_body_size": "2M",
    "client_max_memory_body_size": "128K",
    "client_max_websocket_message_size": "128K",
    "reuse_port": false,
    "listeners": [
      {
        "address": "0.0.0.0",
        "port": 8080
      }
    ]
  },
  "plugins": [
    {
      "name": "drogon::plugin::PromExporter",
      "dependencies": [],
      "config": {
        "path": "/metrics"
      }
    },
    {
      "name": "drogon::plugin::AccessLogger",
      "dependencies": [],
      "config": {
        "use_spdlog": true,
        "log_path": "",
        "log_format": "",
        "log_file": "access.log",
        "log_size_limit": 0,
        "use_local_time": true,
        "log_index": 0
      }
    }
  ],
  "db_clients": [
    {
      "rdbms": "postgresql",
      "host": "postgres",
      "port": 5432,
      "dbname": "salonmaster",
      "user": "salonmaster",
      "passwd": "salonmaster",
      "is_fast": false,
      "connection_number": 4,
      "filename": ""
    }
  ],
  "custom_config": {
    "ai": {
      "deepseek_api_key": "${DEEPSEEK_API_KEY}",
      "model": "deepseek-chat"
    },
    "keycloak": {
      "client_id": "salonmaster-backend",
      "client_secret": "",
      "realm": "salonmaster",
      "server_url": "http://keycloak:8080"
    },
    "app": {
      "master_key": "dev-master-key-change-in-production"
    }
  }
}
